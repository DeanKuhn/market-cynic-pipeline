# --- Environment & Dependencies ---
venv/
.venv/
env/
bin/
lib/
.env

# --- Python Artifacts ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# --- Data & Persistence Strategy ---
# 1. Ignore the directory contents by default
data/*

# 2. Force Git to track the directory structure even if empty
!.gitkeep

# 3. ALLOW the specific database file to be committed
!data/market_history.parquet

# 4. Ignore all other data artifacts
data/*.json
data/*.csv
data/*.sqlite

# --- IDE & OS Garbage ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Project Specifics ---
logs/
test-results/
playwright-report/
misc.txt